# Azure Storage
AZURE_STORAGE_ACCOUNT=nabmaksg
VIDEO_BASE_URL=https://nabmaksg.blob.core.windows.net/raw-video
INDEXED_VIDEO_BASE_URL=https://nabmaksg.blob.core.windows.net/indexed-video

# Container SAS token (User Delegation, read+list, expires 2026-04-08)
# Regenerate weekly with: az storage container generate-sas --account-name nabmaksg --name raw-video --permissions rl --expiry <+7days> --auth-mode login --as-user --https-only --output tsv
CONTAINER_SAS=se=2026-04-08T15%3A53Z&sp=rl&spr=https&sv=2022-11-02&sr=c&skoid=c1dbee16-5385-4c61-8e3f-89216819c88b&sktid=16b3c013-d300-468d-ac64-7eda0820b6d3&skt=2026-04-01T15%3A53%3A53Z&ske=2026-04-08T15%3A53%3A00Z&sks=b&skv=2022-11-02&sig=TVIj%2FWuebLVwJh5iS12Q3ZIdvL8u0vJQxDB27Tg5aTA%3D

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=nab-video-segments

# Azure Content Understanding (Foundry Resource)
AZURE_CU_ENDPOINT=
AZURE_CU_KEY=

# Azure OpenAI — API key auth is DISABLED on this resource; script uses Entra (az login)
# Endpoint: base URL only, no path suffix
AZURE_OPENAI_ENDPOINT=https://makfoundrywestus.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
